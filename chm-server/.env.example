# ============================================================
# 🌐 VARIÁVEIS DE AMBIENTE - CHM SERVER
# ============================================================
# Copie este arquivo para .env e preencha com seus dados

# ============================================================
# 🔌 MONGODB (Para migração Firebird → MongoDB)
# ============================================================
# Obtenha em: https://www.mongodb.com/cloud/atlas
# Formato: mongodb+srv://usuario:senha@cluster.mongodb.net/dbname
# Deixe em branco para usar apenas Firebird
MONGODB_URL=mongodb+srv://seu-usuario:sua-senha@cluster.mongodb.net/chm

# ============================================================
# 🤖 GROQ API (Para assistente de IA)
# ============================================================
# Obtenha em: https://console.groq.com
GROQ_API_KEY=seu-api-key-aqui

# ============================================================
# 🖥️  AWS (Para produção em AWS)
# ============================================================
# IP público da instância EC2 (se hospedando no AWS)
AWS_IP=seu-ip-publico-aws.com

# ============================================================
# 📦 PORT
# ============================================================
PORT=4000
